# ============================================================
# Gleam OpenClaw API Solana — Environment Configuration
# ============================================================

# ---- Solana Configuration ----
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_WS_URL=wss://api.mainnet-beta.solana.com
SOLANA_NETWORK=mainnet-beta
# Treasury wallet that receives MEME token payments
TREASURY_WALLET_ADDRESS=
# Helius API for enhanced Solana RPC
HELIUS_API_KEY=

# ---- MEME Token Configuration ----
# Accepted SPL token mint addresses (comma-separated)
ACCEPTED_TOKEN_MINTS=
# Default cost per OpenClaw API call (in token smallest unit)
DEFAULT_CALL_COST=1000000

# ---- AI Model API Keys ----
OPENAI_API_KEY=
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=
GOOGLE_AI_API_KEY=
KIMI_API_KEY=
ANTHROPIC_API_KEY=

# ---- OpenClaw Configuration ----
OPENCLAW_API_BASE_URL=http://localhost:3000/api
OPENCLAW_AGENT_TIMEOUT=172800000
OPENCLAW_CHECKPOINT_ENABLED=true

# ---- Tavily Search ----
TAVILY_API_KEY=

# ---- Browser Agent ----
BROWSER_USER_DATA_DIR=
BROWSER_HEADLESS=true
BROWSER_TYPE=chromium

# ---- Platform Integrations ----
TELEGRAM_BOT_TOKEN=
LARK_APP_ID=
LARK_APP_SECRET=

# ---- Database ----
DATABASE_URL=mysql://root:password@localhost:3306/openclaw
REDIS_URL=redis://localhost:6379

# ---- Server ----
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
JWT_SECRET=your-jwt-secret-here
