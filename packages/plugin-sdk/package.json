{
  "name": "@gleam-openclaw/plugin-sdk",
  "version": "2.0.0",
  "description": "Plugin SDK for OpenClaw — discover, install, and map Claude/Codex/Cursor plugins to OpenClaw skills",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": { "import": "./dist/index.js", "types": "./dist/index.d.ts" }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "test": "vitest run",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "eventemitter3": "^5.0.1",
    "semver": "^7.5.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "tsup": "^8.0.0",
    "vitest": "^1.2.0"
  },
  "license": "MIT"
}
