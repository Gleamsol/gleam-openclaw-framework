{
  "name": "@gleam-openclaw/core",
  "version": "2.0.0",
  "description": "OpenClaw Agent core engine — task orchestration, checkpoint, and skill execution",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": { "import": "./dist/index.js", "types": "./dist/index.d.ts" }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "test": "vitest run",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@gleam-openclaw/model-router": "workspace:*",
    "@gleam-openclaw/solana-gateway": "workspace:*",
    "eventemitter3": "^5.0.1",
    "uuid": "^9.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "tsup": "^8.0.0",
    "vitest": "^1.2.0",
    "@types/uuid": "^9.0.0"
  },
  "license": "MIT"
}
