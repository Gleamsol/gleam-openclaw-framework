{
  "name": "@gleam-openclaw/model-router",
  "version": "2.0.0",
  "description": "Unified AI model router supporting GPT-5.4, MiniMax M2.7, Gemini-3-flash, Kimi-K2.5, Anthropic Vertex and more",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "test": "vitest run",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "openai": "^4.28.0",
    "eventemitter3": "^5.0.1",
    "p-retry": "^6.2.0",
    "p-queue": "^8.0.1"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "tsup": "^8.0.0",
    "vitest": "^1.2.0"
  },
  "license": "MIT"
}
